def onGpuTypeChanged(kwargs):
    """
    Callback when rpfarm_gputype ordinal changes.
    Syncs the value to rpfarm_gputypeid string parameter.
    """
    node = kwargs.get("node")
    if node is None:
        return
    idx = node.parm("rpfarm_gputype").eval()
    gpu_id = _GPU_TYPE_MAP.get(idx, "")
    if gpu_id:
        node.parm("rpfarm_gputypeid").set(gpu_id)


class RunPodFarmScheduler(EventDispatchMixin, SimpleMQSchedulerMixin, PyScheduler):
    """
    Scheduler implementation that interfaces with RunPod GPU Pods.
    Manages a pool of pods, distributes work items via Redis, and supports
    autoscaling and budget tracking.
    """

    def __init__(self, scheduler, name):
        PyScheduler.__init__(self, scheduler, name)
        SimpleMQSchedulerMixin.__init__(self)
        EventDispatchMixin.__init__(self)

        # Pod pool state: list of dicts with keys:
        # {pod_id, status, created_at, last_heartbeat, idle_since}
        self.pod_infos = []

        # Mapping from task_id (str) to work_item for pending tasks
        self.task_map = {}

        # The underscore-separated prefix used on all job parm names
        self.parmprefix = "rpfarm"

        self._verbose = False
        self._redis_client = None
        self._runpod_headers = {}

        # Cost tracking state, initialized in onStartCook
        self._cost_tracker = {}

        # Autoscaling: rolling window of recent render times (seconds)
        self._render_times = []

