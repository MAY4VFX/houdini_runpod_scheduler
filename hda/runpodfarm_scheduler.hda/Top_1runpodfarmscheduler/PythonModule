    # -------------------------------------------------------------------------
    # MQ Farm Start/Kill (SimpleMQSchedulerMixin interface)
    # -------------------------------------------------------------------------

    def _startFarmMQ(self):
        """
        Starts an MQ server locally. Since we use Redis for task distribution,
        the MQ is only needed for work item result reporting back to PDG.
        The MQ runs on the local machine, not on a remote pod.
        """
        local_conn_file, remote_conn_file = self._getMQConnectionFilePaths()
        taskcallbackport, mqrelayport = self._parsePortParms()

        mq_cmd_exe = "mqserver$PDG_EXE"
        loglvl = min(3, self._verbose + 1)
        mq_cmd_args = (
            f"-p {mqrelayport} -n {MQUtility.MaxConnections} -l {loglvl} "
            f'-c "{local_conn_file}" -w {taskcallbackport} '
            f"{MQUtility.MaxHTTPConnections} {MQUtility.HTTPResult}"
        )

        mq_cmd = f'"{mq_cmd_exe}" {mq_cmd_args}'
        expanded_mq_cmd = self.expandCommandTokens(mq_cmd, None)

        # Start the MQ server locally as a subprocess
        self._verboseLog(f"Starting local MQ server: {expanded_mq_cmd}")

        try:
            self._mq_process = subprocess.Popen(
                expanded_mq_cmd,
                shell=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
            )
        except OSError as e:
            raise CookError(f"Failed to start MQ server: {e}") from e

        self._verboseLog("Waiting for local MQ server to start...")

        try:
            with self._disableConnectionFileTimeout():
                timeout_start = time.time()
                while True:
                    if self.context.canceling:
                        raise CookError(
                            "Cook canceled while connecting to MQ."
                        )

                    time.sleep(0.66)

                    # Check if process is still running
                    if self._mq_process.poll() is not None:
                        exit_code = self._mq_process.returncode
                        raise CookError(
                            f"MQ server exited unexpectedly "
                            f"with code {exit_code}."
                        )

                    # Check for connection file
                    self._getMQAddressFromConnectionFile(local_conn_file)
                    if self.workItemResultServerAddr():
                        break

                    # Safety timeout (5 minutes)
                    if time.time() - timeout_start > 300:
                        raise CookError(
                            "Timed out waiting for MQ connection file."
                        )

        except Exception as e:
            self.setWorkItemResultServerAddr("")
            self._killFarmMQ()
            raise CookError(
                f"Exception while waiting for MQ connection file: {e}"
            ) from e

    def _killFarmMQ(self):
        """
        Stops the local MQ server process.
        """
        mq_process = getattr(self, "_mq_process", None)
        if mq_process is not None:
            try:
                mq_process.terminate()
                mq_process.wait(timeout=5)
            except (subprocess.TimeoutExpired, OSError):
                try:
                    mq_process.kill()
                except OSError:
                    pass
            self._mq_process = None


def submitGraphAsJob(kwargs, node):
    from pdg.scheduler import submitGraphAsJob
    submitGraphAsJob(kwargs, node, 'RunPod Farm')
