# RunPodFarm Configuration
# Copy this file to .env and fill in your values

# === RunPod ===
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_TEMPLATE_ID=
RUNPOD_NETWORK_VOLUME_ID=
RUNPOD_DATACENTER=EU-RO-1

# === Redis (Upstash) ===
REDIS_URL=rediss://default:xxx@eu1-xxx.upstash.io:6379

# === Backblaze B2 (rclone sync) ===
B2_KEY_ID=your_b2_key_id
B2_APP_KEY=your_b2_app_key
B2_BUCKET=runpodfarm-juicefs
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com

# === Compression ===
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=3
STAGING_DIR=/tmp/rpfarm_staging
RCLONE_BIN=/usr/local/bin/rclone

# === NV Cache ===
NV_CACHE_MAX_PCT=80

# === JuiceFS (DEPRECATED — use B2 settings above) ===
# JUICEFS_REDIS_URL=${REDIS_URL}
# JUICEFS_BUCKET_URL=${B2_ENDPOINT}/${B2_BUCKET}
# JUICEFS_CACHE_GROUP=runpodfarm

# === Houdini Licensing ===
SIDEFX_CLIENT_ID=
SIDEFX_CLIENT_SECRET=

# === Project ===
PROJECT_ID=default
USER_ID=artist1

# === Auth API (legacy CF Workers) ===
AUTH_API_URL=https://runpodfarm-auth.workers.dev

# === Server (Node.js — Dokploy deployment) ===
JWT_SECRET=change-this-to-a-secure-random-string
DATABASE_PATH=/app/data/runpodfarm.db
CORS_ORIGIN=*
PORT=3000
